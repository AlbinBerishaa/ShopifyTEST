{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="section-{{ section.id }}-padding">
  <section class="w-full h-auto">
    <div class=" text-2xl text-blue-700{%  if section.settings.side == "left" %} text-left{% endif %}
    {%  if section.settings.side == "middle" %} text-center {% endif %}
    {%  if section.settings.side == "right" %} text-right {% endif %} ">
      {{ section.settings.custom_text }}</div>
  </section>
</div>

{% schema %}
  {
    "name": "Custom-section",
    "tag": "section",
    "class": "section",
    "settings": [
      {
        "type": "text",
        "id": "custom_text",
        "label": "Text",
        "default": "Custom Text"
      },
      {
        "label": "Text Align",
        "type": "select",
        "id": "side",
        "options": [
          {
            "label": "Left",
            "value": "left"
          }, {
            "label": "Middle",
            "value": "middle"
          }, {
            "label": "Right",
            "value": "right"
          }

        ]

      },
      {
        "type": "header",
        "content": "t:sections.all.padding.section_padding_heading"
      },
      {
        "type": "range",
        "id": "padding_top",
        "min": 0,
        "max": 100,
        "step": 4,
        "unit": "px",
        "label": "t:sections.all.padding.padding_top",
        "default": 36
      }, {
        "type": "range",
        "id": "padding_bottom",
        "min": 0,
        "max": 100,
        "step": 4,
        "unit": "px",
        "label": "t:sections.all.padding.padding_bottom",
        "default": 36
      }
    ],
    "presets": [
      {
        "name": "Custom Section"
      }
    ]
  }


{% endschema %}