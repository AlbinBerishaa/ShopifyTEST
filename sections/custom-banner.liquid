{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<section class="w-full h-auto relative">
  {% if section.settings.banner %}
    <img
      src={{ section.settings.banner | image_url }}
      width="100%"
      height="100%"
      class="max-h-200" />
  {% endif %}
  <div class="absolute flex flex-col gap-6 h-auto w-auto bg-yellow-50/65 rounded-sm
 bottom-2/12 left-16 pt-6 pb-4 pl-6 pr-6">
    <p class="text-[94px] font-[fantasy]">{{ section.settings.title }}</p>
    <p class="text-6xl font-semibold">
      {{ section.settings.description }}</p>
    <div class="flex gap-4 mt-6">
      <a href="{{ section.settings.login-link }}" class="w-fit p-4 border border-black rounded-md text-white bg-black min-w-36 text-center">{{ section.settings.login-text }}</a>
      <a href="{{ section.settings.link }}" class="w-fit p-4 border border-black rounded-md hover:bg-black hover:text-white transition duration-300">{{ section.settings.button }}</a>
    </div>
  </div>
</section>

{% schema %}
  {
    "name": "Custom-banner",
    "tag": "section",
    "class": "banner",
    "settings": [
      {
        "type": "image_picker",
        "id": "banner",
        "label": "Banner"
      },
      {
        "type": "text",
        "id": "title",
        "label": "Title",
        "default": "Title"
      },
      {
        "type": "textarea",
        "id": "description",
        "label": "Description",
        "default": "Description"
      },
      {
        "type": "text",
        "id": "button",
        "label": "Button Text",
        "default": "Learn more"
      }, {
        "type": "url",
        "id": "link",
        "label": "Link"
      }, {
        "type": "text",
        "id": "login-text",
        "default": "Login",
        "label": "Login Text"
      }, {
        "type": "url",
        "id": "login-link",
        "label": "Login Link"
      }
    ],
    "presets": [
      {
        "name": "Custom banner"
      }
    ]
  }


{% endschema %}